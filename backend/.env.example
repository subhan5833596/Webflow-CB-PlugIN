# ─────────────────────────────────────────────
# Required in production
# ─────────────────────────────────────────────

# Symmetric encryption key for CB secrets at rest.
# Generate one ONCE with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this stable across deploys — if you change it, old encrypted secrets
# become unreadable and users will have to re-enter them.
STORAGE_KEY=

# Admin token. When set, /api/sites and /api/rules require
#   Authorization: Bearer <ADMIN_TOKEN>
# Leave blank for local development only.
ADMIN_TOKEN=

# Public base URL of THIS server (used for OAuth redirects).
APP_BASE_URL=https://your-domain.example.com


# ─────────────────────────────────────────────
# Only needed if you publish the Designer App
# to the Webflow App marketplace (OAuth flow)
# ─────────────────────────────────────────────

WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=
WEBFLOW_REDIRECT_URI=https://your-domain.example.com/oauth/callback
